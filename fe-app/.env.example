# Dev SFTP push loop for `yarn watch:sftp` — pushes the built main.js (and the
# neutral source trees) to a live test router. Copy to `.env` and fill in.
SFTP_HOST=192.168.1.1
SFTP_PORT=22
SFTP_USER=root
SFTP_PASS=

# Use an SSH key instead of a password if you prefer:
# SFTP_PRIVATE_KEY=~/.ssh/id_rsa

# NOTE: __PKG_NAME__ is the brand package name on the device (e.g. `daypass`).
# The remote view dir is /www/luci-static/resources/view/<pkg>. The built bundle
# lives under packages/luci-app/htdocs/luci-static/resources/view/app locally
# and is renamed to view/<pkg> on the device by the package Makefile — so when
# testing on a real router point REMOTE_DIR_FE at the installed brand path.
LOCAL_DIR_FE=../packages/luci-app/htdocs/luci-static/resources/view/app
REMOTE_DIR_FE=/www/luci-static/resources/view/daypass
