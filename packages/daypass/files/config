config __PKG_NAME__ 'main'
	option enabled '0'
	option log_level 'warning'
	option api_secret ''
	option dashboard '__DASHBOARD__'
	# Path to a gzipped mihomo binary to unpack to tmpfs when /usr/bin/mihomo is
	# absent (small-flash routers). Empty = /usr/lib/__PKG_NAME__/mihomo.gz.
	option mihomo_gz ''

config settings 'settings'
	option dns_type 'udp'
	option dns_server '1.1.1.1'
	option bootstrap_dns_server '1.1.1.1'
	# Optional multi-resolver lists (override dns_server / bootstrap). Plain IPs
	# are the most reliable; DoH (https://…) works but is slower to bootstrap.
	#list nameservers '1.1.1.1'
	#list nameservers '8.8.8.8'
	#list proxy_server_nameservers '1.1.1.1'
	list source_network_interfaces 'br-lan'
	option update_interval '1d'
	option disable_quic '0'
	option dont_touch_dhcp '0'
	option shutdown_correctly '1'
	# selective: only listed domains/subnets go through mihomo (efficient).
	# full: all LAN traffic is tproxied to mihomo, so every rule (incl. ipcidr)
	# applies and MATCH defaults to DIRECT. Use 'full' for rich custom rule sets.
	option routing_mode 'selective'
	# Raw mihomo rule lines. prepend_rules run FIRST (DIRECT/REJECT exceptions,
	# private-IP bypasses); append_rules run after generated rules, before MATCH.
	#list prepend_rules 'AND,((NETWORK,udp),(DST-PORT,443)),REJECT'
	#list prepend_rules 'IP-CIDR,10.0.0.0/8,DIRECT,no-resolve'
	#list prepend_rules 'IP-CIDR,192.168.0.0/16,DIRECT,no-resolve'

# Subscription (mihomo proxy-provider). mihomo fetches + health-checks it.
#config subscription 'lagom'
#	option enabled '1'
#	option url 'https://example.com/sub'
#	option interval '3600'
#	option user_agent 'clash.meta'
#	option health_check_url 'https://www.gstatic.com/generate_204'
#	option health_check_interval '300'

# Proxy group. Members come from: proxy_string (one URL), links (many URLs),
# outbound_json (raw mihomo proxy), and/or subscriptions (proxy-providers).
config proxy 'PROXY'
	option enabled '0'
	option type 'select'
	option proxy_string ''
	#list links 'vless://...'
	#list subscriptions 'lagom'
	#option include_direct '1'

# Custom rule-provider. behavior: domain|ipcidr|classical; format: mrs|yaml|text;
# action: PROXY|DIRECT|REJECT or a proxy group name.
#config ruleset 'ads'
#	option enabled '1'
#	option url 'https://example.com/ads.mrs'
#	option behavior 'domain'
#	option format 'mrs'
#	option action 'REJECT'
#	option interval '86400'

# Routing bucket for community lists / inline domains -> a proxy group.
config route 'route'
	option enabled '0'
	option proxy 'PROXY'
	list community_lists 'russia_inside'
