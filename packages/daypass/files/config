config __PKG_NAME__ 'main'
	option enabled '0'
	option log_level 'warning'
	option api_secret ''
	option dashboard '__DASHBOARD__'
	# Path to a gzipped mihomo binary to unpack to tmpfs when /usr/bin/mihomo is
	# absent (small-flash routers). Empty = /usr/lib/__PKG_NAME__/mihomo.gz.
	option mihomo_gz ''

config settings 'settings'
	option dns_type 'udp'
	option dns_server '1.1.1.1'
	option bootstrap_dns_server '1.1.1.1'
	# Optional multi-resolver lists (override dns_server / bootstrap). Plain IPs
	# are the most reliable; DoH (https://…) works but is slower to bootstrap.
	#list nameservers '1.1.1.1'
	#list nameservers '8.8.8.8'
	#list proxy_server_nameservers '1.1.1.1'
	list source_network_interfaces 'br-lan'
	option update_interval '1d'
	option disable_quic '0'
	option dont_touch_dhcp '0'
	option shutdown_correctly '1'
	# selective: only listed domains/subnets go through mihomo (efficient).
	# full: all LAN traffic is tproxied to mihomo, so every rule (incl. ipcidr)
	# applies and MATCH defaults to DIRECT. Use 'full' for rich custom rule sets.
	option routing_mode 'selective'
	# Sensible defaults: drop QUIC so browsers fall back to TCP/TLS, and never
	# proxy local / private / CGNAT ranges (matters in full mode).
	list prepend_rules 'AND,((NETWORK,udp),(DST-PORT,443)),REJECT'
	list prepend_rules 'IP-CIDR,10.0.0.0/8,DIRECT,no-resolve'
	list prepend_rules 'IP-CIDR,172.16.0.0/12,DIRECT,no-resolve'
	list prepend_rules 'IP-CIDR,192.168.0.0/16,DIRECT,no-resolve'
	list prepend_rules 'IP-CIDR,127.0.0.0/8,DIRECT,no-resolve'
	list prepend_rules 'IP-CIDR,169.254.0.0/16,DIRECT,no-resolve'
	list prepend_rules 'IP-CIDR,224.0.0.0/4,DIRECT,no-resolve'
	list prepend_rules 'IP-CIDR,100.64.0.0/10,DIRECT,no-resolve'

# The proxy group. With no subscription/link yet it stays DIRECT; add a
# subscription on the Connection page and every node is drawn in automatically.
config proxy 'PROXY'
	option enabled '1'
	option type 'select'

# Subscription (mihomo proxy-provider) — add yours on the Connection page:
#config subscription 'my_sub'
#	option enabled '1'
#	option url 'https://example.com/sub'

# --- shipped rule-sets: block ads, route RU-blocked resources through PROXY ---

config ruleset 'ads'
	option enabled '1'
	option preset 'ads'
	option behavior 'domain'
	option format 'mrs'
	option action 'REJECT'
	option url 'https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/meta/geo/geosite/category-ads-all.mrs'
	option interval '86400'

config ruleset 'ru_blocked_domains'
	option enabled '1'
	option preset 'ru_unblock'
	option behavior 'domain'
	option format 'mrs'
	option action 'PROXY'
	option url 'https://github.com/frayZV/runetfreedom-mrs/releases/latest/download/ru-blocked-all.mrs'
	option interval '86400'

config ruleset 'ru_blocked_ips'
	option enabled '1'
	option preset 'ru_unblock'
	option behavior 'ipcidr'
	option format 'mrs'
	option action 'PROXY'
	option no_resolve '1'
	option url 'https://raw.githubusercontent.com/runetfreedom/russia-blocked-geoip/release/mrs/re-filter.mrs'
	option interval '86400'
