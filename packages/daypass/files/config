config __PKG_NAME__ 'main'
	option enabled '0'
	option log_level 'warning'
	option api_secret ''
	option dashboard '__DASHBOARD__'
	# Path to a gzipped mihomo binary to unpack to tmpfs when /usr/bin/mihomo is
	# absent (small-flash routers). Empty = /usr/lib/__PKG_NAME__/mihomo.gz.
	option mihomo_gz ''

config settings 'settings'
	option dns_type 'doh'
	option dns_server 'https://1.1.1.1/dns-query'
	option bootstrap_dns_server '1.1.1.1'
	list source_network_interfaces 'br-lan'
	option update_interval '1d'
	option disable_quic '0'
	option dont_touch_dhcp '0'
	option shutdown_correctly '1'

# Example outbound. Paste a vless://, ss://, trojan:// or hysteria2:// string
# into proxy_string, set enabled '1', and reference this section from a route.
# (UCI section names must be unique across the whole file, so this is 'proxy',
# not 'main'.)
config proxy 'proxy'
	option enabled '0'
	option type 'url'
	option proxy_string ''

# Example routing bucket: which lists go through which proxy.
config route 'route'
	option enabled '0'
	option proxy 'proxy'
	list community_lists 'russia_inside'
