msgid "External (URL) or local (file) rule providers, each routed to an action."
msgstr "Внешние (URL) или локальные (файл) провайдеры правил, каждый со своим действием."

msgid "Extra CIDR subnets to route through the proxy."
msgstr "Дополнительные подсети (CIDR) для маршрутизации через прокси."

msgid "Extra domains to route through the proxy."
msgstr "Дополнительные домены для маршрутизации через прокси."

msgid "Failed to resolve the dashboard address"
msgstr "Не удалось определить адрес дашборда"

msgid "Failed to switch %s"
msgstr "Не удалось переключить %s"

msgid "Fallback (first alive)"
msgstr "Fallback (первый живой)"

msgid "For ipcidr rules: match on the destination IP without a DNS lookup."
msgstr "Для правил ipcidr: сопоставлять по IP назначения без DNS-запроса."

msgid "Format"
msgstr "Формат"

msgid "Full (all traffic via mihomo)"
msgstr "Full (весь трафик через mihomo)"

