msgstr "В Shadowsocks URL нет разделителя credentials@server"

msgid "Shadowsocks URL is missing the port"
msgstr "В Shadowsocks URL отсутствует порт"

msgid "Shadowsocks URL is missing the server host"
msgstr "В Shadowsocks URL отсутствует хост сервера"

msgid "Shadowsocks URL must not contain whitespace"
msgstr "Shadowsocks URL не должен содержать пробелов"

msgid "Shadowsocks URL must start with ss://"
msgstr "Shadowsocks URL должен начинаться с ss://"

msgid "Silent"
msgstr "Тихий"

msgid "Skip the dnsmasq takeover. Advanced: you must repoint client DNS to mihomo yourself."
msgstr "Не перехватывать dnsmasq. Для продвинутых: перенаправить DNS клиентов на mihomo придётся вручную."

msgid "Some providers gate content on the client User-Agent."
msgstr "Некоторые провайдеры отдают контент в зависимости от User-Agent клиента."

msgid "Start"
msgstr "Запустить"

msgid "Start %s automatically and route selected traffic through the proxy."
msgstr "Автоматически запускать %s и направлять выбранный трафик через прокси."

